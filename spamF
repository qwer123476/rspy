local loopSpamActive = false
spamTab:CreateToggle({
    Name = "무한 스팸 잡기 (락/강제수송)",
    CurrentValue = false,
    Flag = "LoopSpamToggle",
    Callback = function(Value)
        loopSpamActive = Value
        if loopSpamActive then
            task.spawn(function()
                table.clear(playersInLoop2V)
                for i, e in ipairs(playersInLoop1V) do
                    local nameOnly = e:match("^(.-) %(") or e
                    table.insert(playersInLoop2V, nameOnly)
                end
                for i, name in ipairs(playersInLoop2V) do
                    local target = game.Players:FindFirstChild(name)
                    if target then pullSinglePlayerFast(target, i) end
                end
                while loopSpamActive do
                    UpdateCurrentBlobman()
                    local myChar = plr.Character
                    local myHrp = myChar and myChar:FindFirstChild("HumanoidRootPart")
                    if myHrp and currentBlobS then
                        for i, name in ipairs(playersInLoop2V) do
                            local target = game.Players:FindFirstChild(name)
                            if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                                local hrp = target.Character.HumanoidRootPart
                                if (myHrp.Position - hrp.Position).Magnitude > 50 then
                                    pullSinglePlayerFast(target, i)
                                end
                                local targetCF = myHrp.CFrame * CFrame.new(math.sin(i) * 3, 20, math.cos(i) * 3)
                                hrp.CFrame = targetCF
                                SetNetworkOwner:FireServer(hrp, targetCF)
                                DestroyGrabLine:FireServer(hrp, targetCF)
                                BlobGrab(currentBlobS, hrp, "Right")
                                BlobRelease(currentBlobS, hrp, "Right")
                            end
                        end
                    end
                    task.wait()
                end
            end)
        end
    end
})

local blobLoopT2 = false
